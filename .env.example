# CareBridge Environment Configuration
# Copy this to .env and fill in your values

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Twilio ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
TWILIO_WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok.io

# --- Infrastructure ---
RABBITMQ_URL=amqp://guest:guest@localhost/
REDIS_URL=redis://localhost:6379
DATABASE_URL=sqlite+aiosqlite:///./carebridge.db

# --- App ---
DEMO_MODE=true

# --- Optional: CLI scripts (demo_flow, trigger_followup, seed_data) ---
# Defaults match local dev and Docker Compose published ports on localhost.
# FRONTEND_URL=http://localhost:3000
# BRAIN_AGENT_URL=http://localhost:8001
# COMM_AGENT_URL=http://localhost:8002
# DB_AGENT_URL=http://localhost:8003
# SCHEDULER_URL=http://localhost:8004
